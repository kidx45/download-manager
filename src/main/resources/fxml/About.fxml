<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="download.manager.controller.AboutController"
      spacing="20" alignment="CENTER"
      stylesheets="@../css/about.css">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <children>
        <Label text="About Download Manager" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Separator maxWidth="400"/>
        
        <VBox spacing="10" alignment="CENTER">
            <children>
                <Label text="Version: 1.0" style="-fx-font-size: 16px;"/>
                <Label text="Release Date: May 29, 2026" style="-fx-font-size: 16px;"/>
                <Label text="Creators: Group 4" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </children>
        </VBox>
        
        <Separator maxWidth="400"/>
        
        <Label text="A professional and efficient tool for managing your internet downloads. Featuring multi-threaded fetching, resumable downloads, and a clean user interface." 
               wrapText="true" textAlignment="CENTER" maxWidth="500" style="-fx-font-size: 14px; -fx-font-style: italic;"/>
        
        <Label text="Built with JavaFX, Maven, and MySQL." style="-fx-text-fill: gray;"/>
    </children>
</VBox>
