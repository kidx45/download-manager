<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="download.manager.controller.DownloadController"
            prefWidth="880" prefHeight="580">

    <!-- TOP: Controls Toolbar -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label text="URL:"/>
                <TextField fx:id="urlField" promptText="Paste download URL here..." HBox.hgrow="ALWAYS"/>
                <Button fx:id="startBtn" text="Start Download" onAction="#onStartClicked"/>
                <Button fx:id="refreshBtn" text="Refresh" onAction="#onRefreshClicked"/>
            </children>
        </HBox>
    </top>

    <!-- LEFT: Sidebar -->
    <left>
        <VBox spacing="10" prefWidth="150">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label text="Navigation" style="-fx-font-weight: bold;"/>
                <Button text="Downloads" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button text="Settings" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button text="About" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            </children>
        </VBox>
    </left>

    <!-- CENTER: Main Data Panel -->
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <VBox spacing="5">
                    <children>
                        <Label text="Progress:"/>
                        <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity"/>
                    </children>
                </VBox>
                <TableView fx:id="table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol"       text="ID"       prefWidth="40"/>
                        <TableColumn fx:id="fileCol"     text="File"     prefWidth="180"/>
                        <TableColumn fx:id="statusCol"   text="Status"   prefWidth="100"/>
                        <TableColumn fx:id="progressCol" text="Progress" prefWidth="70"/>
                        <TableColumn fx:id="urlCol"      text="URL"      prefWidth="250"/>
                        <TableColumn fx:id="actionsCol"  text="Actions"  prefWidth="100"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>

    <!-- BOTTOM: Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="5">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>
            <children>
                <Label text="Status:"/>
                <Label fx:id="statusLabel" text="Ready"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
