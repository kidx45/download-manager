<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="download.manager.controller.MainController"
            prefWidth="880" prefHeight="580"
            id="mainPane">

    <!-- TOP: Simple Page Header -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label fx:id="Page_Name" text="Downloads" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
            </children>
        </HBox>
    </top>

    <!-- LEFT: Sidebar -->
    <left>
        <VBox spacing="10" prefWidth="150">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <children>
                <Label text="Navigation" style="-fx-font-weight: bold;"/>
                <Button text="Downloads" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#onDownloadsNavClicked"/>
                <Button text="Settings" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#onSettingsNavClicked"/>
                <Button text="About" maxWidth="Infinity" alignment="BASELINE_LEFT" onAction="#onAboutNavClicked"/>
            </children>
        </VBox>
    </left>

    <!-- CENTER: Main Content Pane (StackPane holds dynamic content) -->
    <center>
        <StackPane fx:id="contentPane"/>
    </center>

    <!-- BOTTOM: Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="5">
            <padding>
                <Insets top="5" right="10" bottom="5" left="10"/>
            </padding>
            <children>
                <Label text="Status:"/>
                <Label fx:id="statusLabel" text="Ready"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>
