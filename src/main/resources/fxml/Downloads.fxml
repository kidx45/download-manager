<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="download.manager.controller.DownloadsController"
      id="downloads"
      spacing="10"
      stylesheets="@../css/downloads.css">
    
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <children>
        <!-- URL Input Toolbar -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <children>
                <Label text="URL:"/>
                <TextField fx:id="urlField" promptText="Paste download URL here..." HBox.hgrow="ALWAYS" styleClass="search-field"/>
                <Button fx:id="startBtn" id="start_btn" text="Start Download" onAction="#onStartClicked"/>
                <Button fx:id="refreshBtn" text="Refresh" onAction="#onRefreshClicked"/>
            </children>
        </HBox>

        <VBox spacing="5">
            <children>
                <Label text="Progress:"/>
                <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity"/>
            </children>
        </VBox>

        <TableView fx:id="table" id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol"       text="ID"       prefWidth="40"/>
                <TableColumn fx:id="fileCol"     text="File"     prefWidth="180"/>
                <TableColumn fx:id="statusCol"   text="Status"   prefWidth="100"/>
                <TableColumn fx:id="progressCol" text="Progress" prefWidth="70"/>
                <TableColumn fx:id="urlCol"      text="URL"      prefWidth="250"/>
                <TableColumn fx:id="actionsCol"  id="actions" text="Actions"  prefWidth="100"/>
            </columns>
        </TableView>
    </children>
</VBox>
